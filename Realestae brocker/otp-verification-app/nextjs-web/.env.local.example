# ========================================
# 2FACTOR.IN API CONFIGURATION
# ========================================
# Get your API key from: https://2factor.in/
# 1. Sign up at https://2factor.in/
# 2. Login to dashboard
# 3. Copy your API key
# 4. Paste it below

TWOFACTOR_API_KEY=your-2factor-api-key-here

# ========================================
# EMAIL CONFIGURATION (Gmail Example)
# ========================================
# For Gmail: Use App Password, NOT your regular password
# Generate App Password: https://myaccount.google.com/apppasswords
# 1. Enable 2-Step Verification first
# 2. Go to Security > 2-Step Verification > App passwords
# 3. Select "Mail" and "Other (Custom name)"
# 4. Copy the 16-character password (remove spaces)

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here

# ========================================
# BROKER NOTIFICATION EMAIL
# ========================================
# Email address where broker will receive notifications

BROKER_EMAIL=broker@example.com

# ========================================
# OUTLOOK/YAHOO CONFIGURATION (Alternative)
# ========================================
# If using Outlook, use your regular password (no app password needed)
# If using Yahoo, generate app password similar to Gmail
# Update the 'service' in notify-broker/route.js to 'outlook' or 'yahoo'
